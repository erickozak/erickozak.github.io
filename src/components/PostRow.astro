---
import { isoDate, type Post } from '../lib/posts';

interface Props {
  post: Post;
}

const { post } = Astro.props;
const { title, description, pubDate, tags, draft } = post.data;
---

<article class="postrow">
  <time datetime={pubDate.toISOString()}>{isoDate(pubDate)}</time>
  <div>
    <h3>
      <a href={`/writing/${post.id}/`}>{title}</a>
      {draft && <span class="status">draft</span>}
    </h3>
    <p>{description}</p>
    {
      tags.length > 0 && (
        <ul class="tags">
          {tags.map((t) => (
            <li>{t}</li>
          ))}
        </ul>
      )
    }
  </div>
</article>
